# ─────────────────────────────────────────────────────────────────────────────
# My Compliance Paperwork – Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Found in Azure Portal → Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-02-01

# Deployment names (as created in Azure OpenAI Studio)
AZURE_OPENAI_DEPLOYMENT_PRIMARY=gpt-4o
AZURE_OPENAI_DEPLOYMENT_FALLBACK=gpt-4-turbo

# ── Azure Storage ─────────────────────────────────────────────────────────────
# Found in Azure Portal → Storage Account → Access keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# Container/table names (will be created automatically if they don't exist)
AZURE_BLOB_CONTAINER_NAME=documents
AZURE_TABLE_NAME=documents

# ── Processing thresholds ─────────────────────────────────────────────────────
CONFIDENCE_AUTO_APPROVE_THRESHOLD=85.0
CONFIDENCE_MANUAL_REVIEW_THRESHOLD=60.0

# ── App settings ──────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
